# Same-drive backups are the development default; set this to an external drive in production.
ADK_AGENTS_DATA_DIR=/var/lib/adk-agents
ADK_AGENTS_BACKUP_DIR=/var/lib/adk-agents/backups

# Optional until the GitHub adapter is deployed.
# ADK_AGENTS_GITHUB_PROJECT_ID=PVT_xxx
# ADK_AGENTS_GITHUB_OWNER=your-account-or-org
# ADK_AGENTS_GITHUB_REPOSITORY=adk-agents
# ADK_AGENTS_READY_OPTION_ID=option-id
# ADK_AGENTS_IN_PROGRESS_OPTION_ID=option-id
# ADK_AGENTS_BLOCKED_OPTION_ID=option-id
# Required before enabling Project writes; use the immutable GraphQL field IDs.
# ADK_AGENTS_GITHUB_STATUS_FIELD_ID=field-id
# ADK_AGENTS_GITHUB_DISPATCH_FIELD_ID=field-id
# ADK_AGENTS_GITHUB_TOKEN_ENV=GITHUB_TOKEN
